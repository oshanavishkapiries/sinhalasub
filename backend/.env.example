PORT=5001

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=postgres

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=24h
REFRESH_TOKEN_EXPIRY=7d

# Verification / Reset Code TTL
VERIFICATION_CODE_EXPIRY=15m

# Cookie Configuration
# NOTE: For local HTTP development, keep COOKIE_SECURE=false.
COOKIE_SECURE=false
COOKIE_SAMESITE=Lax
COOKIE_DOMAIN=

# SMTP Configuration (for verification/reset emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=SinhalaSub

# TMDB API Configuration
TMDB_API_KEY=your-tmdb-api-key-change-in-production
